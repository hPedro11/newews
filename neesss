class HomePage(QWidget):
    def __init__(self, abrir_ferramenta, parent=None):
        super().__init__(parent)
        v = QVBoxLayout(self)
        v.setContentsMargins(24, 22, 24, 22)

        titulo = QLabel("Central de Ferramentas — Precificação")
        titulo.setFont(QFont("Segoe UI", 15, QFont.Bold))
        sub = QLabel("Selecione uma ferramenta para começar.")
        sub.setStyleSheet("color:#666; font-size:12.5px;")
        v.addWidget(titulo)
        v.addWidget(sub)
        v.addSpacing(12)

        grid = QGridLayout()
        grid.setSpacing(14)
        for i, (nome, desc) in enumerate(TOOLS):
            grid.addWidget(self._card(nome, desc, i, abrir_ferramenta),
                           i // 2, i % 2)
        v.addLayout(grid)

        # Painel de conexão Athena compartilhada
        conexao = QFrame()
        conexao.setProperty("classe", "card")
        hc = QHBoxLayout(conexao)
        hc.setContentsMargins(16, 12, 16, 12)
        led = QLabel("●")
        led.setStyleSheet("color:#4caf50; font-size:14px;")
        txt = QLabel("<b>Conexão Athena:</b> ativa — compartilhada por todas as ferramentas.")
        txt.setStyleSheet("font-size:12.5px;")
        btn_testar = QPushButton("Testar conexão")
        btn_testar.setProperty("classe", "cinza")
        btn_testar.setCursor(Qt.PointingHandCursor)
        hc.addWidget(led)
        hc.addWidget(txt)
        hc.addStretch()
        hc.addWidget(btn_testar)
        v.addSpacing(14)
        v.addWidget(conexao)
        v.addStretch()

    def _card(self, nome, desc, indice, abrir_ferramenta):
        card = QFrame()
        card.setProperty("classe", "card")
        card.setMinimumHeight(130)
        card.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        cv = QVBoxLayout(card)
        cv.setContentsMargins(16, 14, 16, 14)

        lbl_nome = QLabel(nome)
        lbl_nome.setFont(QFont("Segoe UI", 11, QFont.Bold))
        lbl_desc = QLabel(desc)
        lbl_desc.setWordWrap(True)
        lbl_desc.setStyleSheet("color:#666; font-size:12.5px;")

        btn = QPushButton("Abrir")
        btn.setProperty("classe", "acao")
        btn.setCursor(Qt.PointingHandCursor)
        btn.clicked.connect(lambda _, ix=indice: abrir_ferramenta(ix))

        cv.addWidget(lbl_nome)
        cv.addWidget(lbl_desc)
        cv.addStretch()
        cv.addWidget(btn, alignment=Qt.AlignRight)
        return card


class IsinPage(QWidget):
    """Exemplo completo do padrão — substitua os dados fake pela sua lógica
    (isin_backend.py entra aqui quase sem mudança)."""

    def __init__(self, parent=None):
        super().__init__(parent)
        v = QVBoxLayout(self)
        v.setContentsMargins(24, 20, 24, 20)
        v.setSpacing(4)

        titulo = QLabel("ISIN — Preenchimento de Títulos Públicos")
        titulo.setFont(QFont("Segoe UI", 14, QFont.Bold))
        sub = QLabel("Fonte do ISIN: AWS Athena (cad_cadastro_selic_sor).")
        sub.setStyleSheet("color:#666; font-size:12.5px;")
        v.addWidget(titulo)
        v.addWidget(sub)
        v.addSpacing(6)

        # Datas de referência (componente compartilhado)
        self.datas = PainelDatas(
            "Datas de referência (posição — aplicadas no Athena)",
            campos=[("Data inicial:", "13/07/2026"), ("Data final:", "13/07/2026")],
        )
        v.addWidget(self.datas)

        # Parâmetros
        parametros = QGroupBox("Parâmetros")
        hp = QHBoxLayout(parametros)
        hp.addWidget(QLabel("Sigla:"))
        self.sigla = QLineEdit("LZ")
        self.sigla.setFixedWidth(80)
        hp.addWidget(self.sigla)
        hp.addSpacing(18)
        self.rb_athena = QRadioButton("AWS Athena")
        self.rb_athena.setChecked(True)
        self.rb_csv = QRadioButton("CSV de títulos públicos — backup")
        hp.addWidget(self.rb_athena)
        hp.addWidget(self.rb_csv)
        hp.addStretch()
        v.addWidget(parametros)

        # Ações (componente compartilhado)
        self.acoes = BarraAcoes()
        self.acoes.processar_clicado.connect(self.processar)
        self.acoes.limpar_clicado.connect(self.limpar)
        v.addWidget(self.acoes)

        # Prévia
        previa = QGroupBox("Prévia dos dados processados — Posições sem ISIN")
        vp = QVBoxLayout(previa)
        self.tabela = QTableWidget(0, 3)
        self.tabela.setHorizontalHeaderLabels(["Código", "Título", "Status"])
        self.tabela.horizontalHeader().setSectionResizeMode(QHeaderView.Stretch)
        self.tabela.verticalHeader().setVisible(False)
        self.tabela.setFixedHeight(130)
        vp.addWidget(self.tabela)
        v.addWidget(previa)

        # Log (componente compartilhado)
        self.log = CaixaLog()
        v.addWidget(self.log)
        v.addStretch()

    # ---- Ações de exemplo (troque pela chamada ao seu backend) ----
    def processar(self):
        self.limpar()
        dados = [
            ("5320746", "LTN 2027", "ISIN preenchido"),
            ("5322715", "NTN-B 2030", "ISIN preenchido"),
            ("5323243", "LFT 2028", "SEM ISIN"),
        ]
        for codigo, nome, status in dados:
            linha = self.tabela.rowCount()
            self.tabela.insertRow(linha)
            self.tabela.setItem(linha, 0, QTableWidgetItem(codigo))
            self.tabela.setItem(linha, 1, QTableWidgetItem(nome))
            item = QTableWidgetItem(status)
            if status == "SEM ISIN":
                item.setBackground(QColor("#fdecea"))
                item.setForeground(QColor("#b71c1c"))
            else:
                item.setBackground(QColor("#e6f4e6"))
                item.setForeground(QColor("#1b5e20"))
            self.tabela.setItem(linha, 2, item)

        self.log.info("Posições carregadas do Athena: 128")
        self.log.info("ISIN preenchidos: 127")
        self.log.aviso("1 posição sem ISIN — verificar código 5323243")
        self.log.info("Processamento finalizado.")

    def limpar(self):
        self.tabela.setRowCount(0)
        self.log.limpar()


