# ----------------------------------------------------------------------
# 2. Componentes reutilizáveis (usados pelas 4 ferramentas)
# ----------------------------------------------------------------------
class PainelDatas(QGroupBox):
    """Grupo 'Datas de referência' com pares rótulo + campo."""

    def __init__(self, titulo="Datas de referência", campos=None, parent=None):
        super().__init__(titulo, parent)
        self.inputs = {}
        v = QVBoxLayout(self)
        for rotulo, valor in (campos or []):
            h = QHBoxLayout()
            lbl = QLabel(rotulo)
            lbl.setFixedWidth(90)
            campo = QLineEdit(valor)
            self.inputs[rotulo] = campo
            h.addWidget(lbl)
            h.addWidget(campo)
            v.addLayout(h)


class BarraAcoes(QGroupBox):
    """Grupo 'Ações' com os 4 botões padrão. Conecte pelos sinais."""

    processar_clicado = pyqtSignal()
    gerar_clicado = pyqtSignal()
    limpar_clicado = pyqtSignal()
    abrir_pasta_clicado = pyqtSignal()

    def __init__(self, rotulo_pasta="Abrir Pasta de Saída", parent=None):
        super().__init__("Ações", parent)
        h = QHBoxLayout(self)

        self.btn_processar = self._botao("Processar", "acao", self.processar_clicado)
        self.btn_gerar = self._botao("Gerar", "secundario", self.gerar_clicado)
        self.btn_limpar = self._botao("Limpar Processamento", "acao", self.limpar_clicado)
        self.btn_pasta = self._botao(f"📁 {rotulo_pasta}", "acao", self.abrir_pasta_clicado)

        for b in (self.btn_processar, self.btn_gerar, self.btn_limpar, self.btn_pasta):
            h.addWidget(b)
        h.addStretch()

    def _botao(self, texto, classe, sinal):
        btn = QPushButton(texto)
        btn.setProperty("classe", classe)
        btn.setCursor(Qt.PointingHandCursor)
        btn.clicked.connect(sinal.emit)
        return btn


class CaixaLog(QGroupBox):
    """Grupo 'Processamento' com log colorido ([INFO] azul, [AVISO] laranja)."""

    def __init__(self, parent=None):
        super().__init__("Processamento", parent)
        v = QVBoxLayout(self)
        self.texto = QTextEdit()
        self.texto.setObjectName("log")
        self.texto.setReadOnly(True)
        self.texto.setFixedHeight(110)
        v.addWidget(self.texto)

    def info(self, msg):
        self.texto.append(f'<span style="color:#1565c0;">[INFO] {msg}</span>')

    def aviso(self, msg):
        self.texto.append(
            f'<span style="color:#e65100;font-weight:600;">[AVISO] {msg}</span>')

    def limpar(self):
        self.texto.clear()


