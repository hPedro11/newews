class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Central de Ferramentas — Precificação")
        self.resize(1240, 780)

        central = QWidget()
        self.setCentralWidget(central)
        h = QHBoxLayout(central)
        h.setContentsMargins(0, 0, 0, 0)
        h.setSpacing(0)

        # --- Sidebar (lista + rodapé) ---
        coluna = QVBoxLayout()
        coluna.setContentsMargins(0, 0, 0, 0)
        coluna.setSpacing(0)

        self.sidebar = QListWidget()
        self.sidebar.setObjectName("sidebar")
        self.sidebar.setFixedWidth(225)
        self.sidebar.addItem(QListWidgetItem("🏠  Início"))
        for nome, _ in TOOLS:
            self.sidebar.addItem(QListWidgetItem(f"🔧  {nome}"))

        rodape = QLabel("●  Athena conectado  ·  v1.0")
        rodape.setObjectName("sidebarRodape")
        rodape.setFixedWidth(225)

        coluna.addWidget(self.sidebar)
        coluna.addWidget(rodape)

        # --- Páginas ---
        self.paginas = QStackedWidget()
        self.paginas.addWidget(HomePage(self.abrir_ferramenta))          # 0
        self.paginas.addWidget(PlaceholderPage(                          # 1
            "PRAAS Private — Novos Instrumentos Financeiros",
            "Fonte de dados: AWS Athena.",
            "Sua tela atual entra aqui sem mudanças — as abas internas "
            "(AWS · PRAAS Private · Operações Corretora · MTM Compra) "
            "continuam existindo dentro desta página, com QTabWidget."))
        self.paginas.addWidget(PlaceholderPage(                          # 2
            "Ajuste de Opções Flexíveis — Proventos e Barreiras",
            "Fonte de dados: Excel de proventos, PROD.DAT e AWS Athena via ODBC.",
            "Sua tela atual entra aqui: seleção do Excel e do PROD.DAT, data de "
            "cálculo, ações, prévia (Ativos em EX × Validação PROD) e log."))
        self.paginas.addWidget(IsinPage())                               # 3
        self.paginas.addWidget(PlaceholderPage(                          # 4
            "Exportação de Lastro",
            "Fonte de dados: AWS Athena.",
            "Sua tela atual entra aqui: tipo de carteira, base de destino/atual, "
            "códigos de lastro, datas D0/D-1/D-5, ações e log de processamento."))

        self.sidebar.currentRowChanged.connect(self.trocar_pagina)
        self.sidebar.setCurrentRow(0)

        h.addLayout(coluna)
        h.addWidget(self.paginas, stretch=1)

        self.setStatusBar(QStatusBar())
        self.statusBar().showMessage("Pronto — aguardando ação do usuário.")

    def trocar_pagina(self, indice):
        self.paginas.setCurrentIndex(indice)
        if indice == 0:
            self.statusBar().showMessage("Pronto — aguardando ação do usuário.")
        else:
            self.statusBar().showMessage(f"{TOOLS[indice - 1][0]} — pronto.")

    def abrir_ferramenta(self, indice_ferramenta):
        self.sidebar.setCurrentRow(indice_ferramenta + 1)


if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setStyle("Fusion")
    app.setStyleSheet(QSS)
    janela = MainWindow()
    janela.show()
    sys.exit(app.exec_())
